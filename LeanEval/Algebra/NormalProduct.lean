import Mathlib.Analysis.CStarAlgebra.Fuglede
import EvalTools.Markers

namespace LeanEval
namespace Algebra

/-!
The product of commuting normal elements is normal.

If `a` and `b` are normal elements of a C⋆-algebra that commute with each other, then their
product `a * b` is also normal. The proof requires the Fuglede–Putnam–Rosenblum theorem: from
`Commute a b` and normality of `a`, one deduces `Commute (star a) b`; from normality of `b`
and the latter, one deduces `Commute (star a) (star b)`. With all four elements pairwise
commuting, the normality of `a * b` follows by direct computation:
  `star (a * b) * (a * b) = star b * star a * a * b = ... = a * b * star (a * b)`.

This result is fundamental in operator theory — it implies that commutative C⋆-subalgebras
generated by normal elements consist entirely of normal elements.
-/

@[eval_problem]
theorem isStarNormal_mul_of_commute
    {A : Type*} [NonUnitalCStarAlgebra A]
    {a b : A} (ha : IsStarNormal a) (hb : IsStarNormal b)
    (hab : Commute a b) :
    IsStarNormal (a * b) := by
  sorry

end Algebra
end LeanEval
